# -------------------------------
# Laravel Environment Example
# -------------------------------
# Copy to .env and fill in real values. NEVER commit the real .env file.
# Generate APP_KEY with: docker compose exec app php artisan key:generate

APP_NAME=VeA_EconModels
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database (PostgreSQL + TimescaleDB)
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=econmodels
DB_USERNAME=laravel
DB_PASSWORD=

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Cache / Session / Queue
BROADCAST_DRIVER=log
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Mail (production: use real SMTP; dev: 'log' writes to storage/logs/laravel.log)
MAIL_MAILER=log

# -------------------------------
# Production-only settings (do NOT use in dev)
# -------------------------------
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://econmodels.venta.lv
# LOG_LEVEL=warning
# REDIS_PASSWORD=<strong-random-string>
# DB_PASSWORD=<strong-random-string>
# SESSION_SECURE_COOKIE=true
